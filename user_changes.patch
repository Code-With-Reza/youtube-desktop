+                }
+              },
+            },
+            { type: 'separator' },
+            {
+              label: '🗑️ Remove Extension',
+              click: async () => {
+                const result = await dialog.showMessageBox({
+                  type: 'warning',
+                  title: 'Remove Extension',
+                  message: `Remove "${dir}"?`,
+                  detail: 'This will permanently delete the extension files. This action cannot be undone.',
+                  buttons: ['Cancel', 'Remove'],
+                  defaultId: 0,
+                  cancelId: 0,
